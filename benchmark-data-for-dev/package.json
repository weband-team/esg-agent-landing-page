{
  "name": "esgsync-ai-proxy",
  "version": "1.0.0",
  "description": "Backend server for ESGSync",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "init-db": "node database/init-database.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:scoring": "browserify src/scoring/index.js --standalone ESGScoring -o src/scoring.bundle.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.6.7",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "browserify": "^17.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}
