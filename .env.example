# ──────────────────────────────────────────────────────────────────────────
# ESG Agent Landing Page — environment template
# Copy this file to `.env` and adjust the values for your environment:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# Node environment: "development" locally, "production" on the server.
NODE_ENV=production

# Port the Next.js frontend listens on.
# In production Nginx proxies the public domain to this port (see nginx.conf).
PORT=5743

# ── Regulations Search backend (NestJS, runs separately on port 3001) ────
# Base URL the BROWSER uses to reach the regulations backend (SSE + PDF endpoints).
#   - Leave EMPTY in production: the browser uses the same origin and Nginx
#     proxies /api/lookup and /api/pdf to the backend (avoids mixed-content/CORS).
#   - For local dev the code falls back to http://localhost:3001 automatically.
#   - Set an explicit URL only if the backend is hosted on a different domain.
# NOTE: NEXT_PUBLIC_* values are inlined at BUILD time — set before `npm run build`.
NEXT_PUBLIC_REGULATIONS_API_URL=

# URL the Next.js SERVER uses to reach the NestJS backend directly
# (server-to-server, used by /api/regulations-search/email). Same host in prod.
REGULATIONS_BACKEND_URL=http://localhost:3001
